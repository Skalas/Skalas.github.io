---
interface Props {
  tone?: 'default' | 'note';
}
const { tone = 'default' } = Astro.props;
---

<aside
  class:list={[
    'not-prose my-8 rounded-md border-l-4 px-5 py-4 text-base leading-relaxed',
    tone === 'default'
      ? 'border-[color:var(--link)] bg-[color:var(--color-ink-100)] dark:bg-[color:var(--color-ink-800)]'
      : 'border-[color:var(--border)] bg-[color:var(--surface)]',
  ]}
>
  <slot />
</aside>
