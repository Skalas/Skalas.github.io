---
import { SITE, SOCIAL_LINKS } from '../consts';
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-[color:var(--border)] py-10 text-sm text-[color:var(--text-muted)]">
  <div class="container-wide flex flex-col items-center justify-between gap-6 md:flex-row">
    <p class="text-center md:text-left">
      &copy; {year} {SITE.author.name}. Built with
      <a class="underline" href="https://astro.build" rel="noopener">Astro</a>.
    </p>

    <ul class="flex items-center gap-6">
      {
        SOCIAL_LINKS.map(({ label, href, rel }) => (
          <li>
            <a
              href={href}
              rel={rel}
              class="no-underline text-[color:var(--text-muted)] hover:text-[color:var(--text)]"
              aria-label={label}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>
