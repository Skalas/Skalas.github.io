---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found" description="That page could not be found." noindex>
  <section class="container-prose py-32 text-center">
    <p class="font-sans text-xs uppercase tracking-[0.3em] text-[color:var(--text-muted)]">404</p>
    <h1 class="mt-6 font-serif text-5xl font-semibold">Nothing here.</h1>
    <p class="mt-6 text-lg text-[color:var(--text-muted)]">
      The page you were looking for doesn't exist, or has moved.
    </p>
    <p class="mt-10">
      <a
        href="/"
        class="inline-flex items-center gap-2 rounded-md border border-[color:var(--border)] px-5 py-3 no-underline hover:bg-[color:var(--surface)]"
      >
        ← Back home
      </a>
    </p>
  </section>
</BaseLayout>
