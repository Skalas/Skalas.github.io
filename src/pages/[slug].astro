---
import { getCollection, render } from 'astro:content';
import PostLayout from '../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
  );

  return posts.map((post, i) => {
    const prev = i < posts.length - 1 ? posts[i + 1] : null;
    const next = i > 0 ? posts[i - 1] : null;
    return {
      params: { slug: post.id },
      props: {
        post,
        prev: prev ? { slug: prev.id, title: prev.data.title } : null,
        next: next ? { slug: next.id, title: next.data.title } : null,
      },
    };
  });
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);

const fallbackImage = post.data.hero?.src ?? undefined;
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  updated={post.data.updated}
  author={post.data.author}
  category={post.data.category}
  tags={post.data.tags}
  hero={post.data.hero}
  heroAlt={post.data.heroAlt}
  image={fallbackImage}
  imageAlt={post.data.heroAlt}
  mathjax={post.data.mathjax}
  prev={prev}
  next={next}
>
  <Content />
</PostLayout>
